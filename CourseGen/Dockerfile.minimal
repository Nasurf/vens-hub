# Minimal Dockerfile for CourseGen - fallback option with essential packages only
FROM python:3.11-slim

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Environment variables
ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_ROOT_USER_ACTION=ignore \
    COURSEGEN_COURSES_JSON=/app/data/textbooks/courses.json \
    COURSEGEN_CACHE_DIR=/app/OUTPUT_DATA2/cache \
    CHROMA_PERSIST_DIR=/app/OUTPUT_DATA2/embeddings \
    PYTHONPATH=/app \
    OMP_NUM_THREADS=4

# Install only essential system dependencies
RUN set -eux && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    python3-dev \
    ca-certificates \
    curl \
    wget \
    git \
    unzip \
    # Essential libraries for Python packages
    libjpeg-dev \
    libpng-dev \
    zlib1g-dev \
    libxml2-dev \
    libxslt1-dev \
    # Math libraries
    libblas-dev \
    liblapack-dev \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user
RUN groupadd -r appuser && useradd -r -g appuser appuser
WORKDIR /app

# Copy requirements and install Python packages
COPY requirements.txt ./

# Install Python packages with minimal dependencies
RUN set -eux && \
    python -m pip install --upgrade pip setuptools wheel && \
    pip install --no-cache-dir --timeout=300 -r requirements.txt && \
    # Clean up
    rm -rf /tmp/* /var/tmp/* && \
    mkdir -p /app/OUTPUT_DATA2/embeddings /app/OUTPUT_DATA2/cache && \
    chown -R appuser:appuser /app

# Copy application code
COPY --chown=appuser:appuser . .

# Create data directories
RUN mkdir -p \
    /app/data/textbooks \
    /app/OUTPUT_DATA2/embeddings \
    /app/OUTPUT_DATA2/cache && \
    chown -R appuser:appuser /app/data /app/OUTPUT_DATA2

# Switch to non-root user
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import sys; sys.exit(0)" || exit 1

# Set entrypoint and default command
ENTRYPOINT ["python", "-m", "services.QuestionRag.pipelines.question_generator"]
CMD ["--help"]
