# Vens Hub React web migration
# Copy this to .env.local when local overrides are needed.
# The default points to the Cloudflare Worker already added in the Flutter repo.
VITE_API_BASE_URL=https://vens-hub-api.nasurf25.workers.dev

# Optional overrides. By default both use VITE_API_BASE_URL.
VITE_UPLOAD_API_BASE_URL=https://vens-hub-api.nasurf25.workers.dev
VITE_ASSISTANT_API_BASE_URL=https://vens-hub-api.nasurf25.workers.dev

# Firebase JS SDK can be wired here when the team shares the web config.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
