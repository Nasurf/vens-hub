# Vens Hub web — environment config
# Copy this to .env.local and fill in your values

# Worker API base URL
VITE_API_BASE_URL=https://vens-hub-api.nasurf25.workers.dev

# Optional overrides (defaults to VITE_API_BASE_URL)
VITE_UPLOAD_API_BASE_URL=
VITE_ASSISTANT_API_BASE_URL=

# Firebase web config (from Firebase Console → Project Settings → Web Apps)
# Already wired into src/firebase.ts — override here if needed for different environments
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
