# Vens Hub web — environment config
# Copy this to .env.local and fill in your values

# Worker API base URL
VITE_API_BASE_URL=https://vens-hub-api.nasurf25.workers.dev

# Optional override for AI assistant (defaults to VITE_API_BASE_URL)
VITE_ASSISTANT_API_BASE_URL=

# Firebase web config for the Vens Hub project
# Get the real API key from: Firebase Console → Project Settings → Web Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=vens-hub.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=vens-hub
VITE_FIREBASE_STORAGE_BUCKET=vens-hub.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=617771520988
VITE_FIREBASE_APP_ID=1:617771520988:web:bf365c8a1c2608aacfb519
VITE_FIREBASE_MEASUREMENT_ID=G-KGFF3NWEXQ
