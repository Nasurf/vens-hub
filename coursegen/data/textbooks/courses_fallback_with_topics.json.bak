  {
    "code": "COE 507",
    "offered_by_programs": [
      "COMPUTER ENGINEERING"
    ],
    "title": "MODELLING AND SIMULATION OF COMPUTER SYSTEMS",
    "type": "CORE",
    "units": 2,
    "levels": [
      "500"
    ],
    "semesters": [
      "FIRST"
    ],
    "is_elective": false,
    "description": "This course focuses on Computer Aided Design principles, specifically within the context of PCB design and schematic capture. Students will learn to work with projects and documents, manage libraries, and utilize various view commands for effective design visualization. The course also includes practical exercises to reinforce these concepts.",
    "outline": [
      {
        "title": "Project and Document Management",
        "subtopics": [
          "Creating new projects",
          "Adding existing documents",
          "Removing documents from projects",
          "Project file types",
          "Saving project files"
        ],
        "sources": [
          "S1",
          "S2",
          "S4",
          "S6"
        ]
      },
      {
        "title": "Schematic Document Handling",
        "subtopics": [
          "Adding schematic documents",
          "Saving schematic documents",
          "Schematic libraries",
          "Schematic symbols",
          "Document linking"
        ],
        "sources": [
          "S4",
          "S6"
        ]
      },
      {
        "title": "PCB Document Handling",
        "subtopics": [
          "Creating PCB projects",
          "PCB footprint models",
          "Adding PCB documents",
          "PCB document types",
          "Project panel usage"
        ],
        "sources": [
          "S2",
          "S4"
        ]
      },
      {
        "title": "View Commands - Basic",
        "subtopics": [
          "Fit Document",
          "Fit All Objects",
          "Area View",
          "Around Point View",
          "Zooming"
        ],
        "sources": [
          "S3"
        ]
      },
      {
        "title": "View Commands - Magnification",
        "subtopics": [
          "50% magnification",
          "100% magnification",
          "200% magnification",
          "400% magnification",
          "Display magnification control"
        ],
        "sources": [
          "S3",
          "S5"
        ]
      },
      {
        "title": "View Commands - Advanced",
        "subtopics": [
          "Zoom In",
          "Zoom Out",
          "Pan",
          "Refresh",
          "Cursor movement"
        ],
        "sources": [
          "S3",
          "S7"
        ]
      },
      {
        "title": "Shortcut Keys for View Manipulation",
        "subtopics": [
          "Page Up/Down Zoom",
          "Ctrl+Page Down",
          "Space Bar",
          "Arrow Key Navigation",
