  {
    "code": "COE 520",
    "offered_by_programs": [
      "COMPUTER ENGINEERING"
    ],
    "title": "INTRODUCTION TO MOBILE COMPUTING",
    "type": "ELECTIVE",
    "units": 2,
    "levels": [
      "500"
    ],
    "semesters": [
      "SECOND"
    ],
    "is_elective": true,
    "description": "This course provides an introduction to mobile computing, exploring its applications, challenges, and underlying technologies. It covers the evolution of cellular systems, from 1G to 4G and beyond, and examines the standards, protocols, and architectures that enable modern wireless networks. The course aims to equip students with the knowledge to design and evaluate mobile communication systems based on user requirements.",
    "outline": [
      {
        "title": "Introduction to Mobile Computing",
        "subtopics": [
          "Course aims and overview",
          "Applications of mobile computing",
          "Technical challenges in mobile systems",
          "History and future trends",
          "Course organization and literature"
        ],
        "sources": [
          "S1",
          "S11"
        ]
      },
      {
        "title": "Cellular System Fundamentals",
        "subtopics": [
          "Cell concept and frequency reuse",
          "Multiple access techniques",
          "Basis of cellular systems",
          "Towards a global standard",
          "Cellular network components"
        ],
        "sources": [
          "S2",
          "S4",
          "S10"
        ]
      },
      {
        "title": "1G and 2G Cellular Systems",
        "subtopics": [
          "Analogue voice (1G)",
          "Digital voice (2G)",
          "GSM architecture and operation",
          "Handover types",
          "Early cellular system examples"
        ],
        "sources": [
          "S2",
          "S3",
          "S8"
        ]
      },
      {
        "title": "2.5G and 3G Technologies",
        "subtopics": [
          "GPRS introduction",
          "Voice and data services",
          "IMT2000 and 3GPP",
          "UMTS networks",
          "Moving towards full IP networks"
        ],
        "sources": [
          "S2",
          "S6",
          "S7"
        ]
      },
      {
        "title": "3G Network Operation",
        "subtopics": [
          "3G spectrum and licensing",
          "Handover procedures",
          "Roaming user location",
          "Billing and security considerations",
          "Key network components"
        ],
        "sources": [
          "S6",
          "S7",
          "S10"
        ]
      },
      {
        "title": "4G and Beyond",
        "subtopics": [
          "WiMAX and LTE technologies",
          "Integration of existing technologies",
          "Always Best Connected (ABC) concept",
          "Research opportunities",
          "Evolving technologies"
        ],
        "sources": [
          "S5",
          "S9"
        ]
      },
      {
        "title": "Advanced Antenna Techniques",
        "subtopics": [
          "Multi-carrier modulation",
          "Smart antennas",
          "MIMO technology",
          "Higher throughput considerations",
          "Antenna system design"
        ],
        "sources": [
          "S5"
        ]
      },
      {
        "title": "Cellular System Architecture",
        "subtopics": [
          "Mobile Station (MS)",
          "Base Station System (BSS)",
          "Network Switching System (NSS)",
          "Radio Base Station (RBS)",
          "Base Station Controller (BSC)"
        ],
        "sources": [
          "S8",
          "S10"
        ]
      }
    ],
    "outline_sources": [
      "S1",
      "S10",
      "S11",
      "S2",
      "S3",
      "S4",
      "S5",
      "S6",
      "S7",
      "S8",
      "S9"
    ]
  },
