          "Domestic and industrial supply",
          "Distribution system components"
        ],
        "sources": [
          "S10",
          "S7"
        ]
      },
      {
        "title": "Optimal Dispatch",
        "subtopics": [
          "Incremental fuel cost",
          "Lambda calculation",
          "Generator limits",
          "Equality constraints",
          "Inequality constraints"
        ],
        "sources": [
