          "S2"
        ]
      },
      {
        "title": "Counters & Registers",
        "subtopics": [
          "Asynchronous Counters",
          "Synchronous Counters",
          "Modulus Counters",
          "Shift Registers",
          "Universal Shift Register"
        ],
        "sources": [
          "S1",
          "S2"
        ]
      },
      {
        "title": "Sequential Logic Design",
        "subtopics": [
          "State Tables",
          "State Diagrams",
          "State Reduction",
          "Sequential Circuit Implementation",
          "Asynchronous Sequential Logic"
        ],
        "sources": [
          "S1",
          "S9"
        ]
      }
    ],
    "outline_sources": [
      "S1",
      "S10",
      "S2",
      "S9"
    ]
  },
  {
    "code": "EEE 315",
    "offered_by_programs": [
      "COMPUTER ENGINEERING",
      "ELECTRICAL AND ELECTRONICS ENGINEERING"
    ],
    "title": "ELECTROMAGNETIC FIELD AND WAVES I",
    "type": "CORE",
    "units": 3,
    "levels": [
      "300"
    ],
    "semesters": [
      "FIRST"
    ],
    "is_elective": false,
    "description": "This course, Electromagnetic Field and Waves I, introduces the fundamental principles of electrostatics and electromagnetism. It covers concepts like Coulomb's Law, electric field intensity, and the relationship between electric and magnetic fields, utilizing Gauss's Law and Maxwell's equations to analyze charge distributions and field behavior.",
    "outline": [
      {
        "title": "Electrostatics Fundamentals",
        "subtopics": [
          "Coulomb's Law",
          "Electric Field Intensity",
          "Electric Potential",
          "Permittivity and Electric Constant",
          "Force between charges"
        ],
        "sources": [
          "S1",
          "S6",
          "S9"
        ]
      },
      {
        "title": "Gauss's Law",
        "subtopics": [
          "Electric Flux",
          "Gauss's Law Statement",
          "Application to Charge Distributions",
          "Relationship between E and D",
          "Closed Surface Integral"
        ],
        "sources": [
          "S2",
          "S5"
        ]
      },
      {
        "title": "Electric Fields in Dielectrics",
        "subtopics": [
          "Polarization",
          "Relative Permittivity",
          "Electric Displacement",
          "Boundary Conditions",
          "Dielectric Materials"
        ],
        "sources": [
          "S5",
          "S9"
        ]
      },
      {
        "title": "Electric Field of a Sphere",
        "subtopics": [
          "Uniform Charge Density",
          "Electric Field Inside Sphere",
          "Electric Field Outside Sphere",
          "Gauss's Law Application",
          "Potential Calculation"
        ],
        "sources": [
          "S2"
        ]
      },
      {
        "title": "Electric Dipoles",
        "subtopics": [
          "Dipole Moment Definition",
          "Potential due to Dipole",
          "Radial Component of Electric Field",
          "Angular Component of Electric Field",
          "Dipole Applications"
        ],
        "sources": [
          "S3"
        ]
      },
      {
        "title": "Coaxial Cables",
        "subtopics": [
          "Inner and Outer Conductors",
          "Dielectric Material",
          "Charge Distribution",
          "Electric Field Calculation",
          "Potential Difference"
        ],
        "sources": [
          "S2"
        ]
      },
      {
        "title": "Force Calculations",
        "subtopics": [
          "Force on a Charge in an Electric Field",
          "Force between Two Point Charges",
          "Superposition Principle",
          "Example Problems",
          "Units of Force"
        ],
        "sources": [
          "S6",
          "S8",
          "S9"
        ]
      },
      {
        "title": "Line Charge Distributions",
        "subtopics": [
          "Line Charge Density",
          "Electric Field from Infinite Line",
          "Electric Field from Finite Line",
          "Application to Cylindrical Structures",
          "Potential Calculation"
        ],
        "sources": [
          "S7"
        ]
      }
    ],
    "outline_sources": [
      "S1",
      "S2",
      "S3",
      "S5",
      "S6",
      "S7",
      "S8",
      "S9"
    ]
  },
