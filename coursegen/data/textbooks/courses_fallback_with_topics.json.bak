          "S8"
        ]
      },
      {
        "title": "Reliability in Power Systems",
        "subtopics": [
          "Impact of reliability on force effectiveness",
          "Military standards and handbooks",
          "System-level reliability considerations",
          "Logistical implications of failures",
          "Electronic system reliability"
        ],
        "sources": [
          "S7",
          "S12",
          "S13",
          "S14"
        ]
