  {
    "code": "EEE 514",
    "offered_by_programs": [
      "ELECTRICAL AND ELECTRONICS ENGINEERING"
    ],
    "title": "RELIABILITY ENGINEERING",
    "type": "CORE",
    "units": 2,
    "levels": [
      "500"
    ],
    "semesters": [
      "SECOND"
    ],
    "is_elective": false,
    "description": "This course, Reliability Engineering (EEE 500), provides a comprehensive understanding of reliability, maintainability, and availability principles within engineering systems. Students will learn to assess failure probabilities, interpret failure types, and apply these concepts to both power systems and electronic components, ultimately designing for enhanced reliability. The course covers both theoretical foundations and practical applications of reliability engineering techniques.",
    "outline": [
      {
        "title": "Introduction to Reliability",
        "subtopics": [
          "Reliability definition and importance",
          "Maintainability and Availability concepts",
          "Probabilistic reliability foundations",
          "Failure patterns and time",
          "Repairable vs. Non-Repairable systems"
        ],
        "sources": [
          "S1",
          "S2",
          "S9"
        ]
      },
      {
        "title": "Basic Probability Theory",
        "subtopics": [
          "Probability distributions",
          "Random variables and functions",
          "Mathematical expectation",
          "Binomial and Poisson distributions",
          "Normal and Exponential distributions"
        ],
        "sources": [
          "S4"
        ]
      },
      {
        "title": "Reliability Assessment",
        "subtopics": [
          "Component reliability analysis",
          "Hazard rate and reliability function",
          "Failure causes and types",
          "Bathtub curve interpretation",
          "Preventive maintenance effects"
        ],
        "sources": [
          "S4",
          "S8"
        ]
      },
      {
        "title": "Reliability Prediction Methods",
        "subtopics": [
          "Standards-based prediction techniques",
          "Other reliability prediction approaches",
          "Practical aspects of prediction",
          "Systems reliability modeling",
          "Reliability apportionment"
        ],
        "sources": [
          "S5",
          "S7"
        ]
      },
      {
        "title": "Design for Reliability",
        "subtopics": [
          "DfR process overview",
          "Identifying potential failures",
          "Designing for robustness",
          "Analyzing and verifying designs",
          "Validating reliability improvements"
        ],
        "sources": [
          "S5",
          "S10"
        ]
      },
      {
        "title": "Mechanical Component Reliability",
        "subtopics": [
          "Failure mechanisms in mechanical systems",
          "Stress analysis and environmental factors",
          "Failure modes and effects analysis",
          "Material selection for reliability",
          "Mechanical reliability testing"
        ],
        "sources": [
          "S5",
          "S8",
          "S10"
        ]
      },
      {
        "title": "Qualification Testing",
        "subtopics": [
          "Component selection criteria",
          "Environmental considerations",
          "Performance parameter assessment",
