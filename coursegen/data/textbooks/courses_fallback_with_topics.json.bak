  {
    "code": "COE 302",
    "offered_by_programs": [
      "COMPUTER ENGINEERING"
    ],
    "title": "OBJECT ORIENTED PROGRAMMING",
    "type": "CORE",
    "units": 3,
    "levels": [
      "300"
    ],
    "semesters": [
      "SECOND"
    ],
    "is_elective": false,
    "description": "This course, COE 300 Object Oriented Programming, introduces fundamental programming concepts using Python and C++. It covers program structure, control structures, variables, data types, and the principles of object-oriented programming like inheritance and class hierarchies.",
    "outline": [
      {
        "title": "Program Structure",
        "subtopics": [
          "Basic program syntax",
          "Compilation and execution",
          "Line numbers and comments",
          "Fundamental components",
          "Hello World program"
        ],
        "sources": [
          "S2",
          "S4",
          "S7"
        ]
      },
      {
        "title": "Variables and Data Types",
        "subtopics": [
          "Variable declarations",
          "Mental memory analogy",
          "Assigning values to variables",
          "Data storage",
          "Basic operations"
        ],
        "sources": [
          "S6",
          "S9",
          "S10"
        ]
      },
      {
        "title": "Standard Input/Output",
        "subtopics": [
          "iostream header file",
          "Standard output stream",
          "Insertion operator",
          "Printing to screen",
          "Output sentences and numbers"
        ],
        "sources": [
          "S8"
        ]
      },
      {
        "title": "Control Structures",
        "subtopics": [
          "Repeating code",
          "Decision making",
          "Compound statements",
          "Blocks of code",
          "Program flow control"
        ],
        "sources": [
          "S5"
        ]
      },
      {
        "title": "Inheritance",
        "subtopics": [
          "Class hierarchies",
          "Parent and child classes",
          "Data and method inheritance",
          "Modification of inherited members",
          "Unified object treatment"
        ],
        "sources": [
          "S3"
        ]
      },
      {
        "title": "Base and Derived Classes",
        "subtopics": [
          "Superclass concepts",
          "Subclass concepts",
          "Family of classes",
          "Code reusability",
          "Object relationships"
        ],
        "sources": [
          "S3"
        ]
      },
      {
        "title": "C++ Fundamentals",
        "subtopics": [
          "Header files",
          "Namespaces",
          "Main function",
          "Return statements",
          "Basic C++ syntax"
        ],
        "sources": [
          "S4",
          "S6"
        ]
      },
      {
        "title": "Course Introduction",
        "subtopics": [
          "Object Oriented Programming overview",
          "Course content",
          "Instructor information",
          "Learning objectives",
          "Python and C++ focus"
        ],
        "sources": [
          "S1"
        ]
      }
    ],
    "outline_sources": [
