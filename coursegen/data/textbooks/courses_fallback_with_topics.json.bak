    "is_elective": false,
    "description": "This course, OPERATING SYSTEM, provides a fundamental understanding of operating system concepts and their implementation. It covers core mechanisms for process and memory management, file systems, and concurrency control, alongside an exploration of distributed systems and deadlock handling. Students will gain knowledge of OS design principles through case studies and practical examples.",
    "outline": [
      {
        "title": "Introduction to Operating Systems",
        "subtopics": [
          "OS objectives and functions",
          "Computer system architecture",
          "OS structure and operations",
          "Evolution of OS types",
          "System calls and services"
        ],
        "sources": [
          "S1",
          "S2",
          "S4",
          "S8"
        ]
      },
      {
        "title": "Process Management",
        "subtopics": [
          "Process concept and states",
          "Process scheduling algorithms",
          "Operations on processes",
          "Cooperating processes",
          "Threads and their benefits"
        ],
        "sources": [
          "S3",
          "S7",
          "S4"
        ]
      },
      {
        "title": "CPU Scheduling",
        "subtopics": [
          "Pre-emptive vs Non-preemptive scheduling",
          "Scheduling algorithm comparison",
          "Multiprocessor scheduling",
          "Real-time scheduling",
          "Process synchronization"
        ],
        "sources": [
          "S1",
          "S3"
        ]
      },
      {
        "title": "Inter-Process Communication",
        "subtopics": [
          "Critical section problem",
          "Classical IPC problems",
          "Synchronization mechanisms",
          "Message passing",
          "Shared memory"
        ],
        "sources": [
          "S1",
          "S7"
        ]
      },
      {
        "title": "Memory Management",
        "subtopics": [
          "Virtual memory concepts",
          "Memory allocation techniques",
