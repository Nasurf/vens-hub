          "S10"
        ]
      },
      {
        "title": "Energy Sources",
        "subtopics": [
          "Conventional sources",
          "Hydro power station types",
          "Thermal power stations",
          "Nuclear power stations",
          "Renewable energy sources"
        ],
        "sources": [
