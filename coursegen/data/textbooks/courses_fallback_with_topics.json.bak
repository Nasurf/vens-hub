  {
    "code": "EEE 313",
    "offered_by_programs": [
      "COMPUTER ENGINEERING",
      "ELECTRICAL AND ELECTRONICS ENGINEERING"
    ],
    "title": "ELECTRONICS I",
    "type": "CORE",
    "units": 3,
    "levels": [
      "300"
    ],
    "semesters": [
      "FIRST"
    ],
    "is_elective": false,
    "description": "ELECTRONICS I provides a foundational understanding of semiconductor devices and their applications in electronic circuits. The course covers diode theory, transistor characteristics, and basic amplifier configurations, preparing students for more advanced analog and digital electronics coursework. It emphasizes both circuit analysis and practical applications of electronic components.",
    "outline": [
      {
        "title": "Semiconductor Materials & Diodes",
        "subtopics": [
          "Semiconductor properties",
          "PN junction formation",
          "Diode characteristics",
          "Diode models",
          "Diode applications"
        ],
        "sources": [
          "S1",
          "S4",
          "S8"
        ]
      },
      {
        "title": "Diode Circuits",
        "subtopics": [
          "Rectifier circuits",
          "Zener diode regulation",
          "Clipper and clamper circuits",
          "Multidiode configurations",
          "Photodiodes and LEDs"
        ],
        "sources": [
          "S1",
          "S2",
          "S9"
        ]
      },
      {
        "title": "Field-Effect Transistors (FETs)",
        "subtopics": [
          "FET operation principles",
          "FET types and characteristics",
          "FET biasing",
          "FET amplifier basics",
          "FET circuit analysis"
        ],
        "sources": [
          "S2",
          "S6",
          "S8"
        ]
      },
      {
        "title": "Bipolar Junction Transistors (BJTs)",
        "subtopics": [
          "BJT operation and configurations",
          "BJT biasing techniques",
          "BJT amplifier characteristics",
          "BJT limits of operation",
          "BJT testing"
        ],
        "sources": [
          "S2",
          "S5",
          "S9"
        ]
      },
      {
        "title": "Basic Amplifier Configurations",
        "subtopics": [
          "Common-emitter amplifiers",
          "Common-collector amplifiers",
          "Common-base amplifiers",
          "Amplifier gain and bandwidth",
          "Amplifier frequency response"
        ],
        "sources": [
          "S2",
          "S3",
          "S10"
        ]
      },
      {
        "title": "Operational Amplifiers (Op-Amps)",
        "subtopics": [
          "Ideal Op-Amp characteristics",
          "Op-Amp circuits",
          "Inverting and non-inverting amplifiers",
          "Op-Amp limitations",
          "Integrated circuit biasing"
        ],
        "sources": [
          "S2",
          "S3",
          "S10"
        ]
      },
      {
        "title": "Frequency Response & AC Analysis",
        "subtopics": [
          "Low-frequency response",
          "High-frequency response",
          "Miller effect",
          "Bode plots",
          "Square-wave testing"
        ],
        "sources": [
          "S3",
          "S7",
          "S10"
        ]
      },
      {
        "title": "Circuit Analysis Techniques",
        "subtopics": [
          "Voltage and current division",
          "Thevenin and Norton equivalents",
          "Load-line analysis",
          "SPICE simulation",
          "Problem-solving approaches"
        ],
        "sources": [
          "S3",
          "S4",
          "S8"
        ]
      }
    ],
    "outline_sources": [
      "S1",
      "S10",
      "S2",
      "S3",
      "S4",
      "S5",
      "S6",
      "S7",
      "S8",
      "S9"
    ]
  },
  {
