  {
    "code": "COE 508",
    "offered_by_programs": [
      "COMPUTER ENGINEERING"
    ],
    "title": "COMPUTER GRAPHICS AND ANIMATION",
    "type": "CORE",
    "units": 3,
    "levels": [
      "500"
    ],
    "semesters": [
      "SECOND"
    ],
    "is_elective": false,
    "description": "This course provides an introduction to the field of computer graphics, covering both 2D and 3D image creation and manipulation. It explores fundamental concepts like raster and vector graphics, color models, and coordinate systems, ultimately focusing on how these elements contribute to the final 2D image displayed on a computer screen. The course also touches upon the foundations of 3D modeling and solid geometry.",
    "outline": [
      {
        "title": "Introduction to Computer Graphics",
        "subtopics": [
          "Image creation and manipulation",
          "Broad and rapidly evolving field",
          "2D as the final output",
          "Animation principles",
          "Applications in various domains"
        ],
        "sources": [
          "S1",
          "S2",
          "S4"
        ]
      },
      {
        "title": "Raster Graphics",
        "subtopics": [
          "Pixel-based image representation",
          "Frame buffer storage",
          "Color values for each pixel",
          "Screen resolution and pixel visibility",
          "Different screen color mechanisms"
        ],
        "sources": [
          "S5",
          "S6",
          "S8"
        ]
      },
      {
        "title": "Vector Graphics",
        "subtopics": [
          "Geometric shapes as image components",
          "Lines, circles, triangles, and rectangles",
          "Shape attributes like thickness and color",
          "Early computing applications",
          "Architectural blueprints and illustrations"
        ],
        "sources": [
          "S3",
          "S6"
        ]
      },
      {
        "title": "Color Models",
        "subtopics": [
          "Primary color combinations",
          "Grayscale representation",
          "Indexed color displays",
          "Color lists and integer specification",
          "Numerical representation of colors"
        ],
        "sources": [
          "S8"
        ]
      },
      {
        "title": "Coordinate Systems",
        "subtopics": [
          "Arbitrary coordinate system choices",
          "Numerical assignment to points",
          "Row and column numbering conventions",
          "Pixel identification using coordinates",
          "Importance of coordinate system awareness"
        ],
        "sources": [
          "S9",
          "S10"
        ]
      },
      {
        "title": "Pixel Coordinates",
        "subtopics": [
          "Rows and columns of pixels",
          "Integer pairs for pixel specification",
          "Column and row numbers",
          "Coordinate system dependency",
          "Pixels versus points"
        ],
        "sources": [
          "S9",
          "S10"
        ]
      },
      {
        "title": "3D Graphics Overview",
        "subtopics": [
          "Focus on 3D model production",
          "Relationship between 2D and 3D",
          "Ideas transferable between dimensions",
          "Scene modeling",
          "Ultimate 2D image output"
        ],
        "sources": [
          "S2",
          "S4",
          "S5"
        ]
      },
      {
        "title": "Constructive Solid Geometry",
        "subtopics": [
          "Building block approach to modeling",
          "Graphics primitives like cubes and cylinders",
          "Boolean operations: Union, Intersection, Difference",
          "Digital model creation and exchange",
          "Foundation for computer-aided design"
        ],
        "sources": [
          "S7"
        ]
      }
    ],
    "outline_sources": [
      "S1",
      "S10",
      "S2",
      "S3",
      "S4",
      "S5",
      "S6",
      "S7",
      "S8",
      "S9"
    ]
  },
