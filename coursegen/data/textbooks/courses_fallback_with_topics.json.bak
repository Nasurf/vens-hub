  {
    "code": "EEE 321",
    "offered_by_programs": [
      "COMPUTER ENGINEERING",
      "ELECTRICAL AND ELECTRONICS ENGINEERING"
    ],
    "title": "ELECTRIC CIRCUIT THEORY I",
    "type": "CORE",
    "units": 3,
    "levels": [
      "300"
    ],
    "semesters": [
      "FIRST"
    ],
    "is_elective": false,
    "description": "This course, ELECTRIC CIRCUIT THEORY I, provides a foundational understanding of electrical networks and circuit analysis techniques. Students will learn to classify networks, apply Kirchhoff's laws, and utilize methods like mesh and nodal analysis to solve for circuit parameters and power dissipation. The course covers both DC and time-varying circuits, alongside essential circuit elements and theorems.",
    "outline": [
      {
        "title": "Circuit Fundamentals",
        "subtopics": [
          "Linear vs. Non-linear Networks",
          "Active vs. Passive Networks",
          "Bilateral and Unilateral Networks",
          "Voltage and Current Sources",
          "Ideal vs. Practical Sources"
        ],
        "sources": [
          "S1",
          "S5"
        ]
      },
      {
        "title": "Ohm's Law & Network Theorems",
        "subtopics": [
          "Limitations of Ohm's Law",
          "Voltage Division Rule",
          "Current Division Rule",
          "Source Transformation",
          "Series and Parallel Circuits"
        ],
        "sources": [
          "S7",
          "S1"
        ]
      },
      {
        "title": "Kirchhoff's Laws",
        "subtopics": [
          "Kirchhoff's Current Law (KCL)",
          "Kirchhoff's Voltage Law (KVL)",
          "Node Analysis",
          "Mesh Analysis",
          "Applying KCL to Nodes"
        ],
        "sources": [
          "S1",
          "S4",
          "S7"
        ]
      },
      {
        "title": "Nodal Analysis",
        "subtopics": [
          "Formulating Nodal Equations",
          "Solving for Node Voltages",
          "Power Calculation",
          "Dependent Sources",
          "Applying KCL at Nodes"
        ],
        "sources": [
          "S4",
          "S7"
        ]
      },
      {
        "title": "Mesh Analysis",
        "subtopics": [
          "Formulating Mesh Equations",
          "Solving for Mesh Currents",
          "Loop Currents",
          "Applying KVL in Loops",
          "Mesh: closed path"
        ],
        "sources": [
          "S1",
          "S4"
        ]
      },
      {
        "title": "Dependent Sources",
        "subtopics": [
          "Voltage-Dependent Current Sources",
          "Current-Dependent Voltage Sources",
          "Dependent Source Analysis",
          "Circuit Modeling",
          "Diamond Representation"
        ],
        "sources": [
          "S5",
          "S4"
        ]
      },
      {
        "title": "Time-Varying Signals",
        "subtopics": [
          "Sinusoidal Signals",
          "Exponential Signals",
          "Time-Variant Sources",
          "AC Source",
          "Signal Representation"
        ],
        "sources": [
          "S5",
          "S8"
        ]
      },
      {
        "title": "Network Functions & Laplace Transforms",
        "subtopics": [
          "Network/Transfer Function",
          "Laplace Transform Basics",
          "Impedance and Admittance",
          "Complex Frequency",
          "Relationship between Input and Output"
        ],
        "sources": [
          "S8",
          "S4"
        ]
      }
    ],
    "outline_sources": [
      "S1",
      "S4",
      "S5",
      "S7",
      "S8"
    ]
  },
