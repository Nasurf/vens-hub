      },
      {
        "title": "Economic Operation of Power Systems",
        "subtopics": [
          "Fixed and variable costs",
          "Electricity price determination",
          "Matching load with generation",
          "Types of generators",
          "Economic dispatch principles"
        ],
        "sources": [
          "S1",
          "S9"
        ]
      },
      {
        "title": "Power Factor Correction",
        "subtopics": [
          "Definition of power factor",
          "True, apparent, and reactive power",
          "Phasor diagrams",
          "Power factor improvement techniques",
          "Example calculations"
        ],
        "sources": [
