        ]
      },
      {
        "title": "Logic Gates & Families",
        "subtopics": [
          "Diode Logic",
          "RTL circuits",
          "TTL circuits",
          "Logic family interfacing",
          "Logic gate analysis"
        ],
        "sources": [
          "S2"
        ]
      },
      {
        "title": "Flip-Flops",
        "subtopics": [
          "RS Flip-Flop",
          "JK Flip-Flop",
          "D Flip-Flop",
