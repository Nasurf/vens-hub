    "code": "COE 405",
    "offered_by_programs": [
      "COMPUTER ENGINEERING"
    ],
    "title": "NUMERICAL COMPUTATIONS",
    "type": "CORE",
    "units": 3,
    "levels": [
      "400"
    ],
    "semesters": [
      "FIRST"
    ],
    "is_elective": false,
    "description": "This COE 400 course covers the fundamental principles of numerical analysis and computation, focusing on the use of computers to solve real-world problems involving real numbers. It emphasizes mathematical principles alongside practical application using software like MATLAB, while also addressing the inherent errors in numerical methods.",
    "outline": [
      {
        "title": "Introduction to Numerical Analysis",
        "subtopics": [
          "Historical development",
          "Applications in engineering",
          "Role of computers",
          "Problem solving approach",
          "Limitations of numerical methods"
        ],
        "sources": [
          "S1",
          "S3"
        ]
      },
      {
        "title": "Number Representation",
        "subtopics": [
          "Decimal vs Binary systems",
          "Floating-point representation",
          "Computer number limitations",
          "Base conversion",
          "Impact on computation"
        ],
        "sources": [
          "S2",
          "S6",
          "S10"
        ]
      },
      {
        "title": "Error Analysis",
        "subtopics": [
          "Sources of error",
          "Absolute and relative error",
          "Truncation error",
          "Round-off error",
          "Error propagation"
        ],
        "sources": [
          "S5",
          "S9"
        ]
      },
      {
        "title": "Numerical Integration",
        "subtopics": [
          "Quadrature rules",
          "Trapezoidal rule",
          "Simpson's rule",
          "Error bounds",
          "Applications"
        ],
        "sources": [
          "S3"
        ]
      },
      {
        "title": "Numerical Optimization",
        "subtopics": [
          "Unconstrained optimization",
          "Constrained optimization",
          "Gradient descent",
          "Applications",
          "Algorithms"
        ],
        "sources": [
          "S3"
        ]
      },
      {
        "title": "Numerical Linear Algebra",
        "subtopics": [
          "Eigenvalue problems",
          "Matrix decomposition",
          "Solving linear systems",
          "Iterative methods",
          "Condition number"
        ],
        "sources": [
          "S3"
        ]
      },
      {
        "title": "Ordinary Differential Equations",
        "subtopics": [
          "Initial value problems",
          "Euler's method",
          "Runge-Kutta methods",
          "Stability analysis",
          "Error control"
        ],
        "sources": [
          "S4",
          "S7",
          "S8",
          "S9"
        ]
      },
      {
        "title": "Numerical Modeling and Simulation",
        "subtopics": [
          "Partial differential equations",
          "Integral equations",
          "Finite difference methods",
          "Finite element methods",
          "Applications in science and engineering"
        ],
        "sources": [
          "S3"
        ]
      }
    ],
    "outline_sources": [
      "S1",
      "S10",
      "S2",
      "S3",
      "S4",
      "S5",
      "S6",
      "S7",
      "S8",
      "S9"
    ]
  },
  {
    "code": "COE 409",
    "offered_by_programs": [
      "COMPUTER ENGINEERING"
    ],
    "title": "PROTOTYPING TECHNIQUES",
    "type": "CORE",
    "units": 2,
    "levels": [
      "400"
    ],
    "semesters": [
      "FIRST"
    ],
    "is_elective": false,
    "description": "This course, PROTOTYPING TECHNIQUES, introduces the fundamental concepts and practical skills required for electronic prototyping. Students will learn to convert ideas into physical representations, evaluate designs, and prepare prototypes for production, encompassing both hardware and software aspects of the prototyping process.",
    "outline": [
      {
        "title": "Introduction to Prototyping",
        "subtopics": [
          "Definition of a prototype",
          "Importance of prototyping",
          "Prototyping as a communication tool",
          "Early evaluation benefits",
          "Prototyping in product development"
        ],
        "sources": [
          "S1",
          "S7",
          "S8"
        ]
      },
      {
        "title": "Electronic Prototyping Concepts",
        "subtopics": [
          "What is an electronic prototype",
          "Importance in electronics",
          "Conversion of ideas to physical form",
          "Early design usability",
          "Concrete representation of a product"
        ],
        "sources": [
          "S2",
          "S3",
          "S7"
        ]
      },
      {
        "title": "Essential Prototyping Steps",
        "subtopics": [
          "Working schematic diagram creation",
          "Circuit simulation",
          "Initial prototype development",
          "Evaluation and testing procedures",
          "Final prototype preparation"
        ],
        "sources": [
          "S3",
          "S2"
        ]
      },
      {
        "title": "Prototyping Techniques & Dimensions",
        "subtopics": [
          "Representation forms (online/offline)",
          "Precision levels",
          "Interactivity considerations",
          "Evolutionary stages",
          "Analysis along four dimensions"
        ],
        "sources": [
          "S4",
          "S5"
        ]
      },
      {
        "title": "Prototype Types",
        "subtopics": [
          "Breadboard prototypes",
          "Functional prototypes",
          "Visual prototypes",
          "Pre-production prototypes",
          "Levels of prototype development"
        ],
        "sources": [
          "S3",
          "S10"
        ]
      },
      {
        "title": "PCB Design Fundamentals",
        "subtopics": [
          "Introduction to PCB design",
          "Single layer PCBs",
          "Double layer PCBs",
          "Multi-layer PCBs",
          "Flexible and flexa/rigid PCBs"
        ],
        "sources": [
          "S9",
          "S10"
        ]
      },
      {
        "title": "Soldering and Packaging",
        "subtopics": [
          "Electronic soldering techniques",
          "Prototype packaging methods",
          "Board enclosure design",
          "Packaging board into enclosure",
          "Importance of proper packaging"
        ],
        "sources": [
          "S6",
          "S3"
        ]
      },
      {
        "title": "Grounding and Shielding",
        "subtopics": [
          "Grounding techniques in electronics",
          "Shielding methods",
          "System usability testing",
          "Fine-tuning system parameters",
          "Scientific evaluations"
        ],
        "sources": [
          "S8",
          "S3"
        ]
      }
    ],
    "outline_sources": [
